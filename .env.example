# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
CHAT_ID=

# ── Bot authorization ─────────────────────────────────────────────────────────
# Your Telegram user ID — always allowed, cannot be removed.
# Get your ID by messaging @userinfobot on Telegram.
TELEGRAM_OWNER_ID=

# ── Optional: NVD API key (higher rate limits) ────────────────────────────────
NVD_API_KEY=

# ── GitHub (required for repo scanning and PR creation) ───────────────────────
GITHUB_TOKEN=

# ── LLM Provider — choose ONE ─────────────────────────────────────────────────

# Option A: OpenRouter (recommended — one key, 200+ models)
# Set llm_provider=openrouter in data/config.json
OPENROUTER_API_KEY=

# Option B: LiteLLM Proxy (self-hosted gateway)
# Set llm_provider=litellm_proxy in data/config.json
LITELLM_API_KEY=
LITELLM_BASE_URL=

# Option C: Google Gemini (direct API, no proxy needed)
# Get a key at https://aistudio.google.com/apikey
# Then set llm_model to a real Gemini model via /setconfig, e.g.:
#   /setconfig llm_model gemini-2.0-flash
GEMINI_API_KEY=

# ── GitHub OAuth App (optional — enables /connectgit Device Flow for github.com) ──
# Register at https://github.com/settings/developers → "New OAuth App"
# After creation, scroll down and enable "Device Authorization Grant"
# Leave blank to use PAT (Personal Access Token) flow instead — works for all providers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── All other settings are in data/config.json ────────────────────────────────
# Edit data/config.json or use /setconfig in Telegram to change:
#   llm_provider, llm_model, nvd_poll_interval_minutes,
#   commit_poll_interval_minutes, severity_threshold, watchlist, etc.
